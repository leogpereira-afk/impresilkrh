# Banco de dados (SQLite — arquivo local, ideal para MVP/demo)
DATABASE_URL="file:./dev.db"

# Chave de assinatura das sessões (JWT). Em produção, gere um valor forte e secreto.
# Ex.: openssl rand -base64 48
AUTH_SECRET="troque-este-valor-em-producao"

# Diretório de armazenamento seguro de documentos
STORAGE_DIR="./storage/uploads"
