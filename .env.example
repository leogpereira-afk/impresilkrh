# ---------------------------------------------------------------------------
# Banco de dados — PostgreSQL
# Em produção serverless (Netlify/Vercel) é OBRIGATÓRIO um Postgres acessível
# pela rede. Opções: "Netlify DB" (Neon), Neon (neon.tech) ou Supabase — todos
# têm plano gratuito. Para desenvolvimento, um Postgres local também funciona.
# ---------------------------------------------------------------------------

# URL de conexão da aplicação (use a versão "pooled" no Neon, com sslmode=require).
DATABASE_URL="postgresql://usuario:senha@host:5432/impresilk?sslmode=require"

# Conexão direta (sem pooler), usada pelas migrações do Prisma.
# No Neon, é a connection string "unpooled". Localmente pode ser igual à de cima.
DIRECT_URL="postgresql://usuario:senha@host:5432/impresilk?sslmode=require"

# Chave de assinatura das sessões (JWT). Gere um valor forte: openssl rand -base64 48
AUTH_SECRET="troque-este-valor-em-producao"

# Diretório de armazenamento de documentos (upload local).
# OBS.: em produção serverless o disco é efêmero — use um armazenamento de objetos.
STORAGE_DIR="./storage/uploads"

# E-mail (opcional) — habilita o envio real de notificações/resumos.
# Sem estas variáveis, o envio funciona em "modo simulado" (apenas log no servidor).
# RESEND_API_KEY="re_xxxxxxxx"
# EMAIL_FROM="rh@suaempresa.com.br"
