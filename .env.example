# Banco de dados (SQLite — arquivo local, ideal para MVP/demo)
DATABASE_URL="file:./dev.db"

# Chave de assinatura das sessões (JWT). Em produção, gere um valor forte e secreto.
# Ex.: openssl rand -base64 48
AUTH_SECRET="troque-este-valor-em-producao"

# Diretório de armazenamento seguro de documentos (upload de arquivos)
STORAGE_DIR="./storage/uploads"

# E-mail (opcional) — habilita o envio real de notificações/resumos.
# Sem estas variáveis, o envio funciona em "modo simulado" (apenas log no servidor).
# RESEND_API_KEY="re_xxxxxxxx"
# EMAIL_FROM="rh@suaempresa.com.br"
