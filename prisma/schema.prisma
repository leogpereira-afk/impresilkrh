// Sistema de RH — Impresilk Comunicação Visual
// Modelo de dados (Prisma + SQLite). Arquitetura modular preparada para evoluir
// com novos módulos (diárias e viagens, ponto, recrutamento, onboarding).

generator client {
  provider      = "prisma-client-js"
  // "native" para desenvolvimento; "rhel-openssl-3.0.x" para o runtime serverless
  // do Netlify (AWS Lambda / Amazon Linux). Necessário para o Prisma rodar em produção.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================== AUTENTICAÇÃO E ACESSO =====================

// Perfis de acesso (SQLite não suporta enum nativo):
//   ADMIN_RH    — Administrador de RH (acesso total)
//   GESTOR      — Gestor (apenas a sua área)
//   COLABORADOR — Colaborador (autoatendimento)

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  senhaHash     String
  perfil        String    @default("COLABORADOR")
  ativo         Boolean   @default(true)
  colaborador   Colaborador? @relation(fields: [colaboradorId], references: [id])
  colaboradorId String?   @unique
  ultimoLogin   DateTime?
  criadoEm      DateTime  @default(now())

  acessosRegistrados AccessLog[] @relation("UsuarioDoAcesso")
  notificacoes       Notificacao[]
}

// Registro LGPD — quem acessou dados pessoais/sensíveis (CPF, salário, família)
model AccessLog {
  id            String   @id @default(cuid())
  usuario       User     @relation("UsuarioDoAcesso", fields: [usuarioId], references: [id])
  usuarioId     String
  acao          String // VISUALIZAR_DADOS_SENSIVEIS, EXPORTAR, EDITAR, etc.
  recurso       String // ex.: "Colaborador:CPF", "Colaborador:Salario"
  colaboradorId String? // alvo do acesso (quando aplicável)
  detalhe       String?
  ip            String?
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
  @@index([usuarioId])
  @@index([criadoEm])
}

// ===================== ESTRUTURA ORGANIZACIONAL =====================

model Area {
  id          String        @id @default(cuid())
  nome        String        @unique
  descricao   String?
  ordem       Int           @default(0)
  cargos      Cargo[]
  colaboradores Colaborador[]
  metas       Meta[]
}

// Régua de senioridade / níveis técnicos (N1..N5)
model Nivel {
  id          String  @id @default(cuid())
  codigo      String  @unique // N1, N2, N3, N4, N5
  nome        String // Júnior, Pleno, Sênior (mapeamento de senioridade)
  senioridade String // Júnior | Pleno | Sênior
  ordem       Int
  descricao   String?

  faixas      FaixaSalarial[]
  colaboradores Colaborador[]
}

model Cargo {
  id          String   @id @default(cuid())
  nome        String
  area        Area     @relation(fields: [areaId], references: [id])
  areaId      String
  descricao   String? // missão do cargo
  responsabilidades       String? // texto / lista
  competenciasTecnicas    String?
  competenciasComportamentais String?
  requisitos              String?
  indicadores             String? // indicadores de desempenho do cargo
  trilha                  String? // chave da trilha (Produção, Comercial, Administrativo)
  faixaMin    Float? // piso (N1)
  faixaMax    Float? // teto (N5)

  faixas        FaixaSalarial[]
  colaboradores Colaborador[]

  @@unique([nome, areaId])
}

// Faixa salarial por cargo e nível (piso/meio/teto derivados de N1/N3/N5)
model FaixaSalarial {
  id        String @id @default(cuid())
  cargo     Cargo  @relation(fields: [cargoId], references: [id], onDelete: Cascade)
  cargoId   String
  nivel     Nivel  @relation(fields: [nivelId], references: [id])
  nivelId   String
  valor     Float

  @@unique([cargoId, nivelId])
}

// Status configurável pelo RH (Ativo, Inativo, Afastado, Em experiência...)
model StatusColaborador {
  id            String        @id @default(cuid())
  nome          String        @unique
  cor           String        @default("#64748b")
  contaComoAtivo Boolean      @default(true)
  ordem         Int           @default(0)
  colaboradores Colaborador[]
}

// ===================== COLABORADORES =====================

model Colaborador {
  id            String   @id @default(cuid())
  // Dados pessoais
  nome          String
  cpf           String?  @unique
  email         String?  @unique
  telefone      String?
  dataNascimento DateTime?
  dataAdmissao  DateTime?
  dataDesligamento DateTime?

  // Endereço
  enderecoRua        String?
  enderecoNumero     String?
  enderecoComplemento String?
  enderecoBairro     String?
  enderecoCep        String?

  // Dados familiares
  conjugeNome     String?
  conjugeTelefone String?
  qtdFilhos       Int      @default(0)

  // Cargo / área / hierarquia
  cargo     Cargo?  @relation(fields: [cargoId], references: [id])
  cargoId   String?
  nivel     Nivel?  @relation(fields: [nivelId], references: [id])
  nivelId   String?
  area      Area?   @relation(fields: [areaId], references: [id])
  areaId    String?
  gestor    Colaborador?  @relation("Hierarquia", fields: [gestorId], references: [id])
  gestorId  String?
  liderados Colaborador[] @relation("Hierarquia")

  // Dados trabalhistas (sensíveis)
  salario         Float?
  matriculaEsocial String?
  valeTransporte  Boolean  @default(false)

  // Status
  status    StatusColaborador? @relation(fields: [statusId], references: [id])
  statusId  String?

  // Enquadramento (Plano de Carreira / pesquisa de mercado)
  refMinMercado   Float?
  refMaxMercado   Float?
  defasagem       Float? // negativo = abaixo do mercado
  posicaoFaixa    String? // Abaixo, Dentro, Acima, Crítico
  statusSalarial  String?
  proximoNivelSugerido String?
  salarioAlvoProximo   Float?
  gapProximoNivel      Float?
  observacaoEnquadramento String?

  // Retenção
  riscoSaida      String?  @default("Baixo") // Baixo, Médio, Alto
  potencial       String?  @default("Médio") // Baixo, Médio, Alto (eixo 9-box)

  criadoEm  DateTime @default(now())

  user          User?
  documentos    Documento[]
  ferias        Ferias[]
  movimentacoes Movimentacao[]
  avaliacoesRecebidas Avaliacao[] @relation("ColaboradorAvaliado")
  avaliacoesFeitas    Avaliacao[] @relation("Avaliador")
  metas         Meta[]
  pdis          PDI[]
  feedbacksRecebidos Feedback[] @relation("FeedbackColaborador")
  feedbacksDados     Feedback[] @relation("FeedbackAutor")
  viagens       Viagem[]
  tarefas       Tarefa[]
  aceites       Aceite[]
  consentimentos ConsentimentoLGPD[]

  @@index([areaId])
  @@index([cargoId])
  @@index([gestorId])
  @@index([statusId])
}

// ===================== DOCUMENTOS =====================

model Documento {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  categoria     String // Contrato, ASO, Exame Periódico, Certificado, Advertência, Comprovante, Outro
  nome          String
  arquivoNome   String?
  arquivoPath   String?
  tamanhoBytes  Int?
  dataEmissao   DateTime?
  dataVencimento DateTime?
  observacao    String?
  enviadoPor    String?
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
  @@index([dataVencimento])
}

// Documentos institucionais (Código de Ética, POPs, Treinamentos, SST: PGR/PCMSO)
model DocumentoInstitucional {
  id        String   @id @default(cuid())
  titulo    String
  categoria String // Código de Ética, POP, Treinamento, SST
  descricao String?
  conteudo  String? // texto / resumo
  arquivoPath String?
  versao    String?
  atualizadoEm DateTime @default(now())
}

// ===================== FÉRIAS =====================

model Ferias {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  periodoAquisitivoInicio DateTime?
  periodoAquisitivoFim    DateTime?
  dataInicio    DateTime?
  dataRetorno   DateTime?
  diasGozados   Int      @default(0)
  saldoDias     Int      @default(30)
  status        String   @default("Em aberto") // Em aberto, Agendada, Em andamento, Concluída
  observacao    String?
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
}

// ===================== HISTÓRICO / MOVIMENTAÇÕES =====================

model Movimentacao {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  tipo          String // Admissão, Promoção, Mudança de Cargo, Reajuste, Afastamento, Retorno
  data          DateTime
  descricao     String?
  cargoAnterior String?
  cargoNovo     String?
  nivelAnterior String?
  nivelNovo     String?
  salarioAnterior Float?
  salarioNovo     Float?
  registradoPor String?
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
}

// ===================== DESEMPENHO =====================

model CicloAvaliacao {
  id         String   @id @default(cuid())
  nome       String   @unique
  dataInicio DateTime
  dataFim    DateTime
  status     String   @default("Aberto") // Aberto, Fechado
  pesoTecnico        Float @default(0.4)
  pesoComportamental Float @default(0.3)
  pesoResultado      Float @default(0.3)
  notaMinPromocao    Float @default(80)
  mesesMinNivel      Int   @default(12)
  criadoEm   DateTime @default(now())

  avaliacoes Avaliacao[]
}

model Avaliacao {
  id            String   @id @default(cuid())
  ciclo         CicloAvaliacao @relation(fields: [cicloId], references: [id], onDelete: Cascade)
  cicloId       String
  colaborador   Colaborador @relation("ColaboradorAvaliado", fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  avaliador     Colaborador? @relation("Avaliador", fields: [avaliadorId], references: [id])
  avaliadorId   String?
  tipo          String   @default("GESTOR") // AUTO (autoavaliação), GESTOR

  notaTecnico        Float?
  notaComportamental Float?
  notaResultado      Float?
  notaFinal          Float?

  statusDesempenho   String? // Apto, Em desenvolvimento, Não apto
  tempoNoNivelMeses  Int?
  advertencia        Boolean @default(false)
  liderancaAprovou   Boolean @default(false)
  elegivelPromocao   Boolean @default(false)
  proximoNivel       String?
  planoAcao          String?
  comentarios        String?
  status             String  @default("Pendente") // Pendente, Em andamento, Concluída
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  @@index([colaboradorId])
  @@index([cicloId])
}

model Meta {
  id            String   @id @default(cuid())
  titulo        String
  descricao     String?
  tipo          String   @default("Individual") // Individual, Área
  colaborador   Colaborador? @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String?
  area          Area?    @relation(fields: [areaId], references: [id])
  areaId        String?
  indicador     String?
  valorAlvo     Float?
  valorAtual    Float?
  unidade       String?
  prazo         DateTime?
  status        String   @default("Em andamento") // Não iniciada, Em andamento, Concluída, Atrasada
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
  @@index([areaId])
}

model PDI {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  competencia   String
  acao          String
  resultadoEsperado String?
  prazo         DateTime?
  status        String   @default("Pendente") // Pendente, Em andamento, Concluída, Atrasada
  progresso     Int      @default(0) // 0-100
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
}

model Feedback {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation("FeedbackColaborador", fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  autor         Colaborador? @relation("FeedbackAutor", fields: [autorId], references: [id])
  autorId       String?
  tipo          String   @default("Contínuo") // Positivo, Desenvolvimento, Contínuo
  conteudo      String
  contexto      String?
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
}

// ===================== LGPD =====================

model ConsentimentoLGPD {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  finalidade    String // Tratamento de dados pessoais, Dados sensíveis, etc.
  consentido    Boolean  @default(false)
  data          DateTime @default(now())

  @@index([colaboradorId])
}

// ===================== VIAGENS E DIÁRIAS =====================
// Controle de deslocamentos e diárias da equipe de campo.

model Viagem {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  destino       String
  dataInicio    DateTime
  dataFim       DateTime
  dias          Int      @default(1)
  valorDiaria   Float    @default(0)
  valorTotal    Float    @default(0)
  finalidade    String?
  status        String   @default("Planejada") // Planejada, Aprovada, Em andamento, Concluída, Cancelada
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
}

// ===================== ONBOARDING / OFFBOARDING =====================
// Checklists de integração (admissão) e desligamento.

model Tarefa {
  id            String   @id @default(cuid())
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  tipo          String // Admissão, Desligamento
  titulo        String
  responsavel   String?
  prazo         DateTime?
  concluida     Boolean  @default(false)
  concluidaEm   DateTime?
  ordem         Int      @default(0)
  criadoEm      DateTime @default(now())

  @@index([colaboradorId])
}

// ===================== NOTIFICAÇÕES =====================
// Alertas in-app por usuário (vencimentos, pendências, avaliações).
// O canal de e-mail é opcional e ativado via provedor configurado em lib/email.ts.

model Notificacao {
  id         String   @id @default(cuid())
  usuario    User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId  String
  chave      String // chave de deduplicação (ex.: doc-venc-<id>)
  tipo       String // Documento, SST, Férias, Avaliação, Integração, Viagem
  severidade String   @default("info") // info, warning, danger
  titulo     String
  mensagem   String?
  link       String?
  lida       Boolean  @default(false)
  criadoEm   DateTime @default(now())

  @@unique([usuarioId, chave])
  @@index([usuarioId])
}

// ===================== ACEITES / ASSINATURAS =====================
// Registro de aceite eletrônico de documentos (Código de Ética, PDI, políticas),
// com data, IP e hash do conteúdo para integridade/trilha de auditoria.

model Aceite {
  id             String   @id @default(cuid())
  colaborador    Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId  String
  tipo           String // Código de Ética, PDI, Política
  referencia     String? // id do documento/PDI relacionado
  versao         String?
  hashConteudo   String?
  nomeConfirmado String?
  ip             String?
  criadoEm       DateTime @default(now())

  @@index([colaboradorId])
}

// ===================== CONFIGURAÇÕES =====================

model Configuracao {
  id     String @id @default(cuid())
  chave  String @unique
  valor  String
}
